# Purpose: Sample environment variables for local setup.
# Website Section: Global Configuration.
# Developer Notes: Copy to .env and fill DB credentials, base URL, Khalti keys, mail settings, and MQTT/GPS endpoints.

APP_ENV=local
APP_DEBUG=true
APP_TIMEZONE=Asia/Kathmandu
BASE_URL=/rentals-app/public

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ridex_db
DB_USER=root
DB_PASS=

# Render-friendly aliases (optional alternatives the app now accepts)
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=
# MYSQL_HOST=
# MYSQL_PORT=
# MYSQL_DATABASE=
# MYSQL_USER=
# MYSQL_PASSWORD=
# DATABASE_URL=
