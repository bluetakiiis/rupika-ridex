#!/usr/bin/env sh
set -eu

if ! command -v php >/dev/null 2>&1; then
  echo "PHP is required to run pre-commit data snapshot." >&2
  exit 1
fi

php bin/sync_vehicles_json.php --prefer-db-timestamps
php bin/export_db_snapshot.php

git add \
  data/vehicles-json/cars.json \
  data/vehicles-json/bikes.json \
  data/vehicles-json/luxury.json \
  data/deploy/db_snapshot.sql
